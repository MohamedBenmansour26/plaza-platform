# Plaza Platform — required environment variables
# Copy this file to .env.local and fill in the values

# Supabase — get from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER-SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostHog — get from your PostHog project settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
